            {
              "key": "location",
              "cssSelector": ".topcard__flavor--bullet"
            },
            {
              "key": "description",
              "cssSelector": ".description__text"
            },
            {
              "key": "jobUrl",
              "cssSelector": ".topcard__link",
              "returnValue": "attribute",
              "attribute": "href"
            }
          ]
        },
        "options": {}
      },
