          "value": {
            "Job Title": "={{ JSON.parse($('Edit Fields1').item.json.jobData).jobTitle }}",
            "Company": "={{ JSON.parse($('Edit Fields1').item.json.jobData).company }}",
            "URL": "={{ JSON.parse($('Edit Fields1').item.json.jobData).jobUrl }}",
            "Match Score": "={{ JSON.parse($('Edit Fields1').item.json.jobData).matchAnalysis }}",
            "Cover Letter": "={{ $json.output }}",
            "Resume Tips": "={{ JSON.parse($('Edit Fields1').item.json.jobData).matchAnalysis }}",
            "Date": "={{ new Date().toISOString().split('T')[0] }}"
          }
        },
        "options": {}
      },
      "id": "a1b2c3d4-0018-4000-8000-000000000018",
      "name": "Append or update row in sheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [1540, 580],
