    {
      "parameters": {
        "sendTo": "={{ $('Get row(s) in sheet').first().json.email || 'YOUR_EMAIL_HERE' }}",
        "subject": "=🔍 Daily Job Search Report - {{ new Date().toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) }}",
        "emailType": "html",
        "message": "=<h2>🔍 Daily Job Search Report</h2>\n<p>Your automated job search found <strong>{{ $json.totalJobs || 'several' }}</strong> matching positions today.</p>\n<p>📊 <a href=\"YOUR_GOOGLE_SHEET_URL_HERE\">View Full Results in Google Sheets</a></p>\n<p>Here are today's top matches:</p>\n<hr>\n<p><em>This email was sent by your n8n Job Search Automation. Check your Google Sheet for detailed match scores, cover letters, and resume tips.</em></p>",
        "options": {}
      },
