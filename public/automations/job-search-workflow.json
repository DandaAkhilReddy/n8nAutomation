      "id": "a1b2c3d4-0012-4000-8000-000000000012",
      "name": "Edit Fields",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [660, 580]
    },
    {
      "parameters": {
        "options": {
          "systemMessage": "You are an expert career coach and job matching AI. Given a resume and a job description, analyze the match and provide:\n1. A match score from 0-100\n2. Key matching skills\n3. Missing skills or gaps\n4. Specific resume improvements for this role\n\nRespond in JSON format:\n{\"matchScore\": number, \"matchingSkills\": [string], \"gaps\": [string], \"resumeTips\": string}"
        },
        "promptType": "define",
        "text": "=Resume:\n{{ $json.resumeText }}\n\n---\n\nJob Title: {{ $json.jobTitle }}\nCompany: {{ $json.company }}\nJob Description:\n{{ $json.fullDescription }}"
      },
      "id": "a1b2c3d4-0013-4000-8000-000000000013",
      "name": "AI Agent",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [880, 580]
    },
    {
      "parameters": {
        "model": "gemini-2.0-flash",
        "options": {
          "temperature": 0.3
        }
      },
      "id": "a1b2c3d4-0014-4000-8000-000000000014",
      "name": "Google Gemini Chat Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [880, 780],
      "credentials": {
        "googleGeminiApi": {
          "id": "CONFIGURE_YOUR_GEMINI_CREDENTIAL",
          "name": "Google Gemini API"
        }
      }
    },
    {
      "parameters": {
