              "value": "={{ JSON.stringify({ jobTitle: $('Edit Fields').item.json.jobTitle, company: $('Edit Fields').item.json.company, jobUrl: $('Edit Fields').item.json.jobUrl, matchAnalysis: $json.output }) }}",
              "type": "string"
            }
          ]
        },
        "options": {}
      },
      "id": "a1b2c3d4-0015-4000-8000-000000000015",
      "name": "Edit Fields1",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1100, 580]
    },
    {
      "parameters": {
        "options": {
          "systemMessage": "You are an expert cover letter writer. Given job details and match analysis, write a concise, compelling cover letter (250-350 words) tailored to this specific role.\n\nThe cover letter should:\n- Address the company and role specifically\n- Highlight the candidate's relevant skills from the match analysis\n- Address any gaps constructively\n- Be professional but personable\n- Include a strong opening and call to action\n\nReturn ONLY the cover letter text, no JSON or formatting."
        },
        "promptType": "define",
        "text": "=Write a cover letter for this job:\n\n{{ $json.jobData }}"
      },
      "id": "a1b2c3d4-0016-4000-8000-000000000016",
      "name": "AI Agent1",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [1320, 580]
    },
    {
      "parameters": {
        "model": "gemini-2.0-flash",
        "options": {
          "temperature": 0.7
        }
      },
      "id": "a1b2c3d4-0017-4000-8000-000000000017",
      "name": "Google Gemini Chat Model1",
      "type": "@n8n/n8n-nodes-langchain.lmChatGoogleGemini",
      "typeVersion": 1,
      "position": [1320, 780],
      "credentials": {
        "googleGeminiApi": {
          "id": "CONFIGURE_YOUR_GEMINI_CREDENTIAL",
          "name": "Google Gemini API"
        }
      }
    },
    {
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": {
          "__rl": true,
          "mode": "list",
          "value": ""
